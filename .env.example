# ============================================
# Planetary Pulse — Environment Configuration
# ============================================
# Copy this to .env and fill in your keys.
# All integrations are optional — the app works
# with mock data when keys are absent.

# --- Backboard (AI Memory + State) ---
# Get your key at https://app.backboard.io → Settings → API Keys
BACKBOARD_API_KEY=
BACKBOARD_BASE_URL=https://app.backboard.io/api

# --- Auth0 (User + Agent Authentication) ---
# Create at https://auth0.com → Applications → Regular Web App
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_CALLBACK_URL=http://localhost:3000/callback
AUTH0_AUDIENCE=https://planetary-pulse.api

# --- Google Gemini (AI Insights) ---
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Snowflake (Climate Data Warehouse) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=CLIMATE_DATA
SNOWFLAKE_SCHEMA=PUBLIC

# --- Solana (Carbon Credit Tokens) ---
# Use devnet for testing
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=

# --- Server ---
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-random-string
